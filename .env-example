## mandatory

# database
DATABASE_URL=jdbc:postgresql://localhost:5432/communication_ms
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# JWT symmetric key (for local development)
AUTH_TOKEN_SECRET=your-secret-key-here-min-256-bits

# service port
COMMUNICATION-SERVICE-PORT=3001

## optional

# JWT RSA Keys (for production - generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=

# Slack integration
SLACK_ENABLED=
SLACK_BOT_TOKEN=

# SMS integration (Twilio)
SMS_ENABLED=
SMS_ACCOUNT_SID=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=

# Email
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=

# Queue RabbitMQ, check for more config in /common/queue
QUEUE_ENABLED=
RABBIT_HOST=
RABBIT_PORT=
RABBIT_USER=
RABBIT_PASS=

# Email notification templates
TEMPLATE_ID_WELCOME=welcome-email
TEMPLATE_ID_EMAIL_VERIFICATION=email-verification
TEMPLATE_ID_PASSWORD_RESET=password-reset-email
TEMPLATE_ID_SMS_WELCOME=sms-welcome
TEMPLATE_ID_SMS_VERIFICATION=sms-verification
